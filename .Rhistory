# zzz.R
.onLoad <- function(libname, pkgname) {
# 创建一个包内的私有环境
lksColorsEnv <<- new.env()
# 加载配色方案并存储到私有环境中
palettes_path <- system.file("extdata", "palettes.rds", package = pkgname)
# 如果路径存在，加载配色方案
if (file.exists(palettes_path)) {
lksColorsEnv$palettes <- readRDS(palettes_path)
} else {
stop("配色方案丢失：无法找到 palettes.rds 文件")
}
}
loaded_palettes <- readRDS("inst/extdata/palettes.rds")
print(names(loaded_palettes))
